# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# ─── CORS ─────────────────────────────────────────────────────────────────────
# URL of your frontend dev server or production build
FRONTEND_URL=http://localhost:5173

# ─── NOTE: Jira credentials are NEVER stored here ─────────────────────────────
# They are passed per-request via secure request headers from the frontend.
# This keeps credentials out of server config, logs, and environment.
